# Milo homelab Docker Compose env.
# Copy to infra/.env and fill secrets before `docker compose up`.

# API image source
MILO_IMAGE=ghcr.io/vasujain275/milo
MILO_VERSION=v0.1.0

# Optional for deploy.sh if you do not want the default username.
GHCR_USERNAME=vasujain275

# Host ports. Only API is published to the host.
API_HOST_PORT=7007

# Runtime
ENV=production

# Database service credentials. Change POSTGRES_PASSWORD before hosting.
POSTGRES_DB=milo
POSTGRES_USER=milo
POSTGRES_PASSWORD=change-me-postgres-password

# Google OAuth (required). Use Web Application client ID.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Required secrets. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-at-least-32-characters
TOKEN_ENCRYPT_KEY=change-me-to-at-least-32-characters

# TMDB is required for the movie grid / Discover data.
TMDB_API_KEY=your-tmdb-api-key

# Gemini/chat. Prefer GOOGLE_GENERATIVE_AI_API_KEY; GEMINI_API_KEY stays as fallback.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# Provider OAuth, optional unless linking providers in app.
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=milo://auth/callback
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=milo://auth/callback

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

PORT=8080
AUTO_MIGRATE=true
DATABASE_URL=postgres://milo:change-me-postgres-password@postgres:5432/milo?sslmode=disable
REDIS_URL=redis://redis:6379
# Tavily API for agent web_search tool (optional but recommended for current/external facts)
TAVILY_API_KEY=your-tavily-api-key

# Papra Configuration
# Copy to .env and fill in the values before running.
#
# Generate AUTH_SECRET: openssl rand -hex 48

AUTH_SECRET=change-me
APP_BASE_URL=https://papra.vasujain.me

# Auth: set to true for first admin registration, then false to lock it down
AUTH_IS_REGISTRATION_ENABLED=true

# Email (Gmail SMTP) — use a Gmail app password, not your real password
EMAILS_DRIVER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAILS_FROM_ADDRESS=Papra <your-email@gmail.com>

# No upload size limit (useful for large scanned PDFs)
DOCUMENT_STORAGE_MAX_UPLOAD_SIZE=0

# File ownership (pi user)
UID=1000
GID=1000
